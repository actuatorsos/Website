# JWT Authentication
# IMPORTANT: Generate a strong random secret of at least 64 characters for production!
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_generate_a_random_64_char_secret_here_now
JWT_EXPIRY_HOURS=24
