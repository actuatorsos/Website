# Database Configuration
SURREAL_URL=127.0.0.1:8000
SURREAL_USER=your_db_user
SURREAL_PASS=your_db_password
SURREAL_NS=Actuators
SURREAL_DB=erp

# Server Configuration
SERVER_HOST=0.0.0.0
