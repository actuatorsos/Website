  "about_intro_text": "<strong>Actuators</strong> is not just a conventional platform — it is a <strong>decentralized digital institution and a lightweight economic operating system</strong>, serving as a digital backbone to unify and steer fragmented entrepreneurship ecosystems.",
  "about_problem_title": "The Systemic Problem",
  "about_problem_1_label": "Fragile Work Environment:",
  "about_problem_1_desc": "A fragmented, high-risk informal economy with broken value chains and no trusted infrastructure.",
  "about_problem_2_label": "Trust Gap & Isolation:",
  "about_problem_2_desc": "Local founders isolated from international markets and diaspora capital due to opaque regulations and lack of transparency.",
  "about_problem_3_label": "Lack of Coordination:",
  "about_problem_3_desc": "Over 200 startups operating with high agility, yet suffocated by the absence of a unified digital infrastructure.",
  "about_sol_erp_title": "Management System (ERP)",
  "about_sol_erp_desc": "Transparent digital operational tools (task management, HR, sales) built for low-connectivity environments, giving companies solid institutional structure.",
  "about_sol_diaspora_title": "Investment & Diaspora Gateway",
  "about_sol_diaspora_desc": "A bridge connecting founders with the diaspora across the Mediterranean (Turkey, Greece, Italy) for transparent mentorship and investment flow.",
  "about_sol_lms_title": "Learning Pathways (LMS)",
  "about_sol_lms_desc": "A platform integrating learning with professional execution to close knowledge gaps and compensate for the lack of institutional training for teams.",
  "about_biz_title": "Access Tiers (Business Model)",
  "about_biz_free": "Free for local youth to establish and access basic ERP modules, removing entry barriers.",
  "about_biz_free_label": "Basic Access (Freemium):",
  "about_biz_premium": "Offered to donors and investors in exchange for ecosystem analytics and transparency reports.",
  "about_biz_premium_label": "Premium Services:",
  "about_imm_title": "Impact Management Framework (IMM)",
  "about_imm_outputs": "Registered companies, completed pathways.",
  "about_imm_outcomes": "Cross-border partnerships, data-driven funding.",
  "about_imm_impact": "Company survival rate and transition from survival to systems change (SDGs 4, 8, 10).",
  "services_intro": "<strong>Actuators</strong> provides standardized software infrastructure enabling entities to perform their operational and financial functions with precision and transparency across the network.",
  "svc_dashboard_title": "Live Dashboards",
  "svc_dashboard_desc": "Integrated management and real-time monitoring of ecosystem resources, with analytics tools and performance metrics to ensure operational continuity at peak efficiency.",
  "svc_workflows_title": "Process Automation (Workflows)",
  "svc_workflows_desc": "Automated workflows to unify procedures from authentication to task completion in a systematic, error-proof manner.",
  "svc_teams_title": "Teams & Resources",
  "svc_teams_desc": "A centralized system for human resource management, role allocation, and permissions structured horizontally to fit distributed networks.",
  "svc_verify_title": "Verification & Documentation System",
  "svc_verify_desc": "Tamper-proof issuance and authentication of documents and certificates, building a trusted record of operational facts.",
  "svc_layers_title": "Structural Layers",
  "svc_layers_desc": "Layered data ecosystem separating inputs, operational logic, and user interface to enable safe scaling.",
  "svc_access_title": "Secure Access Systems",
  "svc_access_desc": "Encrypted gateways connecting entities and securing the flow of capital, knowledge, and data between system nodes.",

